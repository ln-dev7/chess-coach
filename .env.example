# AI coach (the "✦ AI coach lesson" button). Set ONE provider key below.
# Priority when several are set: Anthropic > OpenAI > Google (Gemini).
# Without any key, the app still works — template lessons, puzzles and analysis
# are fully local. Users can also bring their own key in Settings (BYOK).

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional model override

# OpenAI (GPT) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google (Gemini) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# SEO: your public site origin (no trailing slash). Used for canonical URLs,
# robots.txt, sitemap.xml and Open Graph / Twitter card image URLs.
# Falls back to https://chess-coach.lndev.me when unset.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
